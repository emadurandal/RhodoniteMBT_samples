{
  "name": "rhodonite-mbt-ex",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "native": "moon run cmd/native --target native",
    "native:build": "moon run cmd/native --target native --build-only",
    "browser": "pnpm run browser:build && node scripts/serve-browser.mjs",
    "browser:build": "moon run cmd/browser --target js --build-only",
    "browser:serve": "node scripts/serve-browser.mjs",
    "typescript": "pnpm --dir samples/typescript dev",
    "typescript:build": "pnpm --dir samples/typescript build",
    "typescript:preview": "pnpm --dir samples/typescript preview"
  }
}
